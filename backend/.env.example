# Existing AI endpoint
OPENAI_API_KEY=

# Render dependencies
DATABASE_URL=postgresql://user:password@host:5432/database
REDIS_URL=redis://host:6379/0
PUBLIC_BASE_URL=https://stew-university-backend.onrender.com

# App sessions and encrypted Apple refresh credentials
APP_JWT_SECRET=
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APPLE_TOKEN_ENCRYPTION_KEY=

# Sign in with Apple
APPLE_BUNDLE_ID=com.stewuniversity.ios
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Apple Push Notification service (a separate APNs key is supported)
APNS_ENVIRONMENT=production
APNS_KEY_ID=
APNS_PRIVATE_KEY=

# Private Cloudflare R2 bucket; keep public access disabled
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Platform safety and published policies
PLATFORM_ADMIN_APPLE_SUBJECTS=
TERMS_URL=
PRIVACY_URL=
SUPPORT_URL=
SAFETY_CONTACT_URL=
TERMS_VERSION=2026-01
OBJECTIONABLE_TEXT=

BAND_INLINE_JOBS=false
BAND_AUTO_CREATE_DB=false
